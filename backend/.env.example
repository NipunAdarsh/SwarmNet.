# SwarmNet Backend Configuration Template
# Copy this file to .env and fill in your actual credentials

# --- Server Settings ---
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- CORS Configuration ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8000,https://localhost:8000

# --- Security & Auth ---
# Required for admin operations and WebSocket authentication
ADMIN_SECRET=your-secure-admin-secret-here
WS_AUTH_REQUIRED=true
MAX_BODY_BYTES=10485760

# --- SSL Configuration (Optional) ---
# SSL_CERT_FILE=cert.pem
# SSL_KEY_FILE=key.pem

# --- Supabase Configuration ---
SUPABASE_URL=your-project-url.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Image Validation ---
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp,gif
MAX_IMAGE_WIDTH=4096
MAX_IMAGE_HEIGHT=4096

# --- Evolutionary Strategies (ES) Hyperparameters ---
ES_POPULATION_SIZE=50
ES_SIGMA=0.1
ES_LEARNING_RATE=0.01

# --- Model & NPU Settings ---
# Set to 'true' to simulate NPU on hardware without one
USE_NPU_SIMULATION=false
DEFAULT_MODEL_PATH=backend/model/mobilenetv2-12.onnx

# --- Swarm Discovery ---
MULTICAST_GROUP=239.1.2.3
MULTICAST_PORT=5005
HEARTBEAT_INTERVAL=5

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=120
